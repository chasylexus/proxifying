#!MANAGED-CONFIG https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.surgeconfig interval=3600 strict=false

# ============================================================
# Surge Common Managed Routing Layer
# ============================================================
# Public shared layer for macOS/iOS linked profiles.
# Keep platform-specific [General]/[DNS] and private [Proxy]/[Keystore]
# sections in local entrypoint profiles.

[Proxy Group]
# Standalone placeholders let Surge validate this shared managed layer.
# Real PROXY_T/PROXY_A definitions remain local in wrapper profiles.
PROXY_T = select, DIRECT
PROXY_A = select, DIRECT

[Rule]
# ============================================================
# 1. Priority overrides
# ============================================================
# Keep com.tr before DIRECT carrier suffixes, matching the live router priority.
RULE-SET,https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.ruleset.proxy-t-priority.list,PROXY_T,update-interval=3600

# ============================================================
# 2. DIRECT / bypass baseline
# ============================================================
RULE-SET,https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.ruleset.direct.list,DIRECT,update-interval=3600

# ============================================================
# 3. PROXY_A routing
# ============================================================
# --- Proxifying A domains ---
RULE-SET,https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.ruleset.proxy-a.list,PROXY_A,update-interval=3600

# --- Google AI / Gemini / NotebookLM ---
DOMAIN-SET,https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/google_ai.lst,PROXY_A,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/refs/heads/master/rule/Surge/Gemini/Gemini.list,PROXY_A,update-interval=3600

# --- Streaming / geo-specific A exit ---
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Netflix/Netflix.list,PROXY_A,update-interval=3600

# ============================================================
# 4. PROXY_T domain routing
# ============================================================
# --- Community rule-sets for broad geosite-style coverage ---
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/YouTube/YouTube.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Spotify/Spotify.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Facebook/Facebook.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Instagram/Instagram.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Twitter/Twitter.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Telegram/Telegram.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/TelegramNL/TelegramNL.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/TelegramSG/TelegramSG.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/TelegramUS/TelegramUS.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/TikTok/TikTok.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Discord/Discord.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/LinkedIn/LinkedIn.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Microsoft/Microsoft.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Google/Google.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Wikipedia/Wikipedia.list,PROXY_T,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Amazon/Amazon.list,PROXY_T,update-interval=3600
DOMAIN-SET,https://raw.githubusercontent.com/itdoginfo/allow-domains/refs/heads/main/Services/hdrezka.lst,PROXY_T,update-interval=3600
RULE-SET,https://iplist.opencck.org/?format=clashx&data=domains&wildcard=1&site=telegram.org,PROXY_T,update-interval=3600

# --- Proxifying T domains and keywords ---
RULE-SET,https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.ruleset.proxy-t.list,PROXY_T,update-interval=3600

# ============================================================
# 5. REJECT (ad blocking)
# ============================================================
RULE-SET,https://raw.githubusercontent.com/Ja7ad/ShadowRocket/main/rules/reject/adguards.list,REJECT,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/Ja7ad/ShadowRocket/main/rules/reject/apple.list,REJECT,update-interval=3600
RULE-SET,https://raw.githubusercontent.com/Ja7ad/ShadowRocket/main/rules/reject/spotify.list,REJECT,update-interval=3600

# ============================================================
# 6. PROXY_T IP/CIDR fallback
# ============================================================
# Source-derived compacted union: Throne manual-t, router c/r T lists, Trust Tunnel VPN IP snapshot.
# Nests are minimized by containment only; adjacent ranges are not broadened here.
RULE-SET,https://raw.githubusercontent.com/chasylexus/proxifying/refs/heads/main/surge.ruleset.proxy-t-ip.list,PROXY_T,update-interval=3600

# ============================================================
# 7. Default
# ============================================================
FINAL,DIRECT

[Host]
localhost = 127.0.0.1
